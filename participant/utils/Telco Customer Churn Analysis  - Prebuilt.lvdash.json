{
  "datasets": [
    {
      "name": "dataset1",
      "displayName": "telco_churn",
      "queryLines": [
        "SELECT * FROM vectorcatalog02.`00_shared`.telco_churn"
      ],
      "columns": [
        {
          "displayName": "Churn Rate",
          "description": "Percentage of customers who churned",
          "expression": "SUM(CASE WHEN `Churn` = 'Yes' THEN 1 ELSE 0 END) * 1.0 / COUNT(`*`)"
        }
      ]
    }
  ],
