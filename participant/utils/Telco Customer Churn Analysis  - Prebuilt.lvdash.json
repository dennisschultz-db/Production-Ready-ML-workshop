                  "datasetName": "dataset1",
                  "fields": [
                    {
                      "name": "gender",
                      "expression": "`gender`"
                    },
                    {
                      "name": "measure(Churn Rate)",
                      "expression": "MEASURE(`Churn Rate`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
